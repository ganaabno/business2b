VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_BASE_URL=https://your-domain.com
VITE_GLOBAL_API_ENABLED=true
VITE_GLOBAL_API_BASE_URL=https://b2c-production.up.railway.app
VITE_GLOBAL_API_ORDERS_PATH=/api/payments
VITE_GLOBAL_API_TOURS_PATH=/api/tours
VITE_GLOBAL_TASKS_API_PATH=/api/tasks
VITE_GLOBAL_API_TIMEOUT_MS=8000
VITE_GLOBAL_API_USE_BACKEND_PROXY=true
VITE_GLOBAL_API_ALLOW_DIRECT_BROWSER=false
# Backend API origin only (no /api path)
VITE_API_BASE_URL=https://api.your-domain.com
VITE_LOCAL_API_TARGET=http://localhost:8080
VITE_USE_GLOBAL_TOURS_PRIMARY=true
VITE_GLOBAL_TOURS_FALLBACK_LOCAL=true
VITE_GLOBAL_API_MULTI_BASE_FALLBACK=true
VITE_B2B_DESTINATION_GLOBAL_FALLBACK=true
VITE_USE_EDGE_ADMIN_FUNCTIONS=true
VITE_USE_BACKEND_ADMIN_USERS=true
VITE_USE_BACKEND_PENDING_USERS=true
VITE_B2B_ROLE_V2_ENABLED=true
VITE_B2B_SEAT_REQUEST_FLOW_ENABLED=true
VITE_B2B_MONITORING_ENABLED=true
VITE_B2B_STRICT_SEAT_ACCESS_BOOKING=true
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Emergency local bypass for backend startup DB compatibility guard
B2B_ALLOW_LEGACY_DB=false
# Optional: disable backend jobs for local legacy DB debugging
B2B_RUN_BACKGROUND_JOBS=false
