{
  "name": "test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/devWithApi.mjs",
    "dev:web": "vite",
    "start": "vite",
    "start:cpanel": "node app.cpanel.mjs",
    "api:dev": "tsx watch backend/src/server.ts",
    "api:start": "node backend/dist/server.js",
    "api:build": "tsc -p backend/tsconfig.json",
    "api:test": "tsx --test backend/src/**/*.test.ts",
    "db:b2b:status": "node scripts/b2bSchemaSetup.mjs --status",
    "db:b2b:apply": "node scripts/b2bSchemaSetup.mjs --apply",
    "db:b2b:legacy-bootstrap": "node scripts/bootstrapB2BLegacyDb.mjs",
    "create-users": "ts-node --esm --project tsconfig.node.json src/createTestUsers.ts",
    "build": "tsc -b && vite build",
    "build:cpanel": "node scripts/verifyCpanelEnv.mjs && npm run api:build && npm run build",
    "lint": "eslint .",
    "typecheck:web": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:api": "tsc -p backend/tsconfig.json --noEmit",
    "typecheck": "npm run typecheck:web && npm run typecheck:api",
    "test:web": "vitest run --config vitest.config.ts",
    "test:web:watch": "vitest --config vitest.config.ts",
    "test:api": "npm run api:test",
    "test:ci": "npm run lint && npm run typecheck && npm run test:api && npm run test:web && npm run api:build && npm run build",
    "preview": "vite preview"
  },
